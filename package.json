{
  "name": "wild-web-wrap-up",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.12.1",
  "scripts": {
    "dev": "next dev",
    "build": "npm run content:validate && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "content:validate": "node scripts/validate-content.mjs",
    "content:buttondown": "node scripts/build-buttondown.mjs",
    "buttondown": "buttondown",
    "buttondown:login": "node scripts/run-buttondown.mjs login --force",
    "buttondown:logout": "buttondown logout",
    "buttondown:pull": "node scripts/run-buttondown.mjs pull --directory=./buttondown",
    "buttondown:prepare": "npm run content:validate && npm run content:buttondown",
    "buttondown:push": "npm run buttondown:prepare && node scripts/sync-buttondown-api.mjs && npm run content:buttondown",
    "buttondown:prune-snippets": "node scripts/prune-buttondown-snippets.mjs",
    "buttondown:verify": "node scripts/verify-buttondown-api.mjs",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "storybook:test": "vitest --config vitest.workspace.ts --project=storybook",
    "storybook:check": "npm run storybook:build && npm run storybook:test"
  },
  "dependencies": {
    "@mdx-js/react": "^3.1.1",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "next-mdx-remote": "^6.0.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@buttondown/cli": "^1.0.9",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/nextjs-vite": "^10.4.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser": "^4.1.7",
    "@vitest/browser-playwright": "^4.1.7",
    "buffer": "^6.0.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.6",
    "playwright": "^1.60.0",
    "prettier": "^3.7.4",
    "storybook": "^10.4.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  }
}
